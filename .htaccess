# Use the root controller when visitors request the domain without a filename.
DirectoryIndex index.php
Options -Indexes
RewriteEngine On

# Public URL normalization: remove direct index.php/index.html requests.
# THE_REQUEST makes these external redirects only, avoiding redirect loops after rewrites.
RewriteCond %{THE_REQUEST} \s/+index\.(?:php|html?)[?\s] [NC]
RewriteRule ^index\.(?:php|html?)$ / [R=302,L,NE]

# Normalize public section index files to their trailing-slash URLs.
RewriteCond %{THE_REQUEST} \s/+((?:about|categories|category|contact|feature-interview|get-featured|privacy|search|stories|story|tag|terms)/)index\.(?:php|html?)[?\s] [NC]
RewriteRule ^((?:about|categories|category|contact|feature-interview|get-featured|privacy|search|stories|story|tag|terms)/)index\.(?:php|html?)$ /$1 [R=302,L,NE]

# Direct access to application internals is never part of the public site.
RewriteRule ^(?:config\.php|includes/|database/|tests/|\.env) - [F,L,NC]

# Friendly dynamic story, category, and tag routes.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(story|category|tag)/[^/]+/?$ $1/index.php [L,QSA]

# The domain root is served by the homepage controller.
RewriteRule ^$ index.php [L]
